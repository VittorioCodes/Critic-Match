# ============================================
# CriticMatch - API Keys
# Bu dosyayı kopyalayıp .env olarak kaydet
# ============================================

# TMDB (The Movie Database) - Filmler & Diziler
# Ücretsiz, anında alınır
# → https://www.themoviedb.org/settings/api
REACT_APP_TMDB_API_KEY=buraya_tmdb_keyini_yaz

# OpenCritic via RapidAPI - Oyun incelemeleri
# Ücretsiz plan: 100 istek/ay
# → https://rapidapi.com/opencritic/api/opencritic-api
REACT_APP_OPENCRITIC_API_KEY=buraya_rapidapi_keyini_yaz

# SteamGridDB - Oyun kapakları/görselleri (OPSÄ°YONEL)
# Ücretsiz, email ile kayıt
# → https://www.steamgriddb.com/profile/preferences/api
# Not: Yoksa OpenCritic görsellerini kullanır (bazılarında eksik olabilir)
REACT_APP_STEAMGRIDDB_API_KEY=buraya_steamgriddb_keyini_yaz
